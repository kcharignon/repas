{% set active = "department" %}
{% extends '@Shared/base.html.twig' %}

{% block title %}
    Rayon : {{ department.name }}
{% endblock %}

{% block body %}
    <ul class="list-group">
        <li class="list-group-item active" aria-current="true">{{ department.name|capitalize }}</li>
        {% for ingredient in ingredients %}
            {% include('@Repas/Department/_ingredient_row.html.twig') %}
        {% endfor %}
        <a class="text-decoration-none text-white list-group-item d-flex justify-content-between align-items-center bg-success" href="{{ path("view_ingredient_create") }}" alt="bouton ajouter">
            Ajouter un ingredient
        </a>
    </ul>
{% endblock %}

{% set active = "recipe" %}
{% extends '@Shared/base.html.twig' %}

{% block title %}Recettes{% endblock %}

{% block body %}
    <div class="row">
        <div class="col">
            <ul class="list-group">
                <li class="list-group-item list-group-item-action active">
                    {{ recipeType.name|capitalize }}
                </li>
                {% for recipe in recipes %}
                    {% include "@Repas/Recipe/_recipe_row.html.twig" %}
                {% endfor %}
                {% if recipes|length < 1 %}
                    <li class="list-group-item"> Vous n'avez pas encore de recette de ce type.</li>
                {% endif %}
            </ul>
        </div>
    </div>
{% endblock %}
